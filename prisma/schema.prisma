// Planbooq Prisma schema
// Auth.js v5 standard models + Workspace/Member/Status/Ticket domain models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------
// Auth.js v5 standard models
// -----------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  preferences   Json?

  accounts        Account[]
  sessions        Session[]
  memberships     Member[]
  createdTickets  Ticket[]     @relation("TicketCreatedBy")
  assignedTickets Ticket[]     @relation("TicketAssignee")
  apiKeys         ApiKey[]
  comments        Comment[]    @relation("CommentAuthor")
  attachments     Attachment[] @relation("AttachmentUploader")
  ticketPreviews  TicketPreview[] @relation("TicketPreviewCreator")
  agents          Agent[]
  agentPairCodes  AgentPairCode[]
  agentProfiles   AgentProfile[]  @relation("AgentProfileCreator")
  authoredMessages   Message[]         @relation("MessageAuthorUser")
  messageReactions   MessageReaction[] @relation("MessageReactionUser")
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String
  prefix      String    @unique
  hash        String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------
// Domain models
// -----------------------------

enum Role {
  OWNER
  MEMBER
}

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     Member[]
  statuses    Status[]
  tickets     Ticket[]
  projects    Project[]
  labels      Label[]
  apiKeys     ApiKey[]
  comments    Comment[]
  attachments Attachment[]
  agents      Agent[]
  workflowTemplates WorkflowTemplate[]
  agentProfiles AgentProfile[]
  conversations Conversation[]
  messages      Message[]
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  slug        String
  name        String
  color       String
  description String?  @db.Text
  repoUrl     String?
  techStack   String?  @db.Text
  githubRepoId    BigInt?
  githubFullName  String?
  localPath   String?
  position    Float
  defaultWorkflowTemplateId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets   Ticket[]
  defaultWorkflowTemplate WorkflowTemplate? @relation("ProjectDefaultWorkflow", fields: [defaultWorkflowTemplateId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, slug])
  @@index([workspaceId, position])
}

model Member {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Status {
  id          String   @id @default(cuid())
  workspaceId String
  key         String
  name        String
  color       String
  position    Float
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets   Ticket[]

  @@unique([workspaceId, key])
  @@index([workspaceId, position])
}

enum Priority {
  NO_PRIORITY
  URGENT
  HIGH
  MEDIUM
  LOW
}

model Ticket {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String
  statusId    String
  title       String
  description String?
  plan        String?   @db.Text
  priority    Priority  @default(NO_PRIORITY)
  assigneeId  String?
  dueDate     DateTime?
  position    Float
  prUrl       String?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    Status    @relation(fields: [statusId], references: [id], onDelete: Cascade)
  createdBy User      @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignee  User?     @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  labels    Label[]   @relation("TicketLabels")
  comments  Comment[]
  previews  TicketPreview[]
  agentJobs AgentJob[]
  activities TicketActivity[]
  workflowSteps WorkflowStep[]
  workflowRuns  WorkflowRun[]
  agentProfileLinks TicketAgentProfile[]
  pullRequests TicketPullRequest[]
  conversation Conversation?

  @@index([workspaceId, statusId, position])
  @@index([projectId, statusId, position])
  @@index([statusId])
  @@index([createdById])
  @@index([assigneeId])
  @@index([workspaceId, dueDate])
}

model Label {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets   Ticket[]  @relation("TicketLabels")

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Comment {
  id          String   @id @default(cuid())
  ticketId    String
  workspaceId String
  authorId    String
  body        String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([workspaceId])
  @@index([authorId])
}

model Attachment {
  id          String   @id @default(cuid())
  workspaceId String
  uploaderId  String
  mimeType    String
  size        Int
  objectKey   String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User      @relation("AttachmentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  previews  TicketPreview[]

  @@index([workspaceId, createdAt])
  @@index([uploaderId])
}

model TicketPreview {
  id           String   @id @default(cuid())
  ticketId     String
  attachmentId String
  label        String?
  position     Int
  createdById  String?
  createdAt    DateTime @default(now())

  ticket     Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("TicketPreviewCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([ticketId, position])
  @@index([attachmentId])
}

// -----------------------------
// Local agent (Claude Code on user's machine)
// -----------------------------

model Agent {
  id           String    @id @default(cuid())
  workspaceId  String
  userId       String
  name         String
  tokenPrefix  String    @unique
  tokenHash    String
  hostname     String?
  platform     String?
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      AgentJob[]
  authoredMessages Message[]         @relation("MessageAuthorAgent")
  messageReactions MessageReaction[] @relation("MessageReactionAgent")

  @@index([workspaceId])
  @@index([userId])
}

model AgentPairCode {
  id        String    @id @default(cuid())
  code      String    @unique
  userId    String
  claimedAt DateTime?
  agentId   String?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum AgentJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

// Outcome classification, distinct from process-level `status`. Inspired by
// Paperclip's `livenessState`: a run can `SUCCEED` at the process level but
// still produce no useful output (`EMPTY_RESPONSE`). Surfacing that separately
// lets the chat thread show an actionable "no output" marker instead of an
// empty conversation that looks like data loss.
enum AgentJobOutcome {
  COMPLETED       // produced text and/or tool use
  EMPTY_RESPONSE  // exited cleanly but emitted nothing visible
  FAILED          // crashed, canceled, or errored
}

model AgentJob {
  id          String         @id @default(cuid())
  agentId     String?
  ticketId    String
  workspaceId String?
  userId      String?
  source      String         @default("PAIRED")
  kind        String         @default("CHAT")
  prompt      String         @db.Text
  status      AgentJobStatus @default(PENDING)
  output      String         @default("") @db.Text
  exitCode    Int?
  error       String?        @db.Text
  worktreePath     String?
  claudeSessionId  String?
  workflowStepRunId String?
  // Outcome classification populated by the mirror layer on terminal status.
  // Nullable so historical rows aren't lying about a classification they
  // never went through.
  outcome     AgentJobOutcome?
  outcomeReason String? @db.Text
  // Continuation lineage. `sourceJobId` points at the prior run in a
  // (future) auto-retry chain; `continuationAttempt` is 0 for user-initiated
  // runs and increments per retry. Wired now so the data model is ready when
  // we add a Retry affordance.
  sourceJobId String?
  continuationAttempt Int @default(0)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agent  Agent? @relation(fields: [agentId], references: [id], onDelete: Cascade)
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sourceJob   AgentJob?  @relation("AgentJobContinuation", fields: [sourceJobId], references: [id], onDelete: SetNull)
  continuations AgentJob[] @relation("AgentJobContinuation")
  activities TicketActivity[]
  messages   Message[]

  @@index([agentId, status])
  @@index([ticketId, createdAt])
  @@index([ticketId, status])
  @@index([ticketId, kind, createdAt])
  @@index([workflowStepRunId])
  @@index([sourceJobId])
  @@index([ticketId, outcome])
}

enum TicketActivityKind {
  PR_CREATED
  PR_MERGED
  COMMIT_PUSHED
  TEST_RUN
  BUILD
  NOTE
  STATUS_CHANGED
  STEP_STARTED
  STEP_COMPLETED
}

model TicketActivity {
  id          String             @id @default(cuid())
  ticketId    String
  workspaceId String
  jobId       String?
  kind        TicketActivityKind
  payload     Json
  createdAt   DateTime           @default(now())

  ticket Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  job    AgentJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([workspaceId, createdAt])
}

// -----------------------------
// Workflows (per-ticket prompt pipelines)
// -----------------------------

model WorkflowTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?  @db.Text
  isGlobal    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps     WorkflowStep[] @relation("TemplateSteps")
  defaultForProjects Project[] @relation("ProjectDefaultWorkflow")

  @@index([workspaceId])
}

model WorkflowStep {
  id         String   @id @default(cuid())
  templateId String?
  ticketId   String?
  name       String
  prompt     String   @db.Text
  position   Float
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template WorkflowTemplate? @relation("TemplateSteps", fields: [templateId], references: [id], onDelete: Cascade)
  ticket   Ticket?           @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([templateId, position])
  @@index([ticketId, position])
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model WorkflowRun {
  id          String            @id @default(cuid())
  ticketId    String
  workspaceId String
  templateId  String?
  status      WorkflowRunStatus @default(PENDING)
  startedAt   DateTime?
  finishedAt  DateTime?
  error       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  ticket   Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  stepRuns WorkflowStepRun[]

  @@index([ticketId, createdAt])
  @@index([workspaceId, createdAt])
}

model WorkflowStepRun {
  id         String            @id @default(cuid())
  runId      String
  position   Int
  name       String
  prompt     String            @db.Text
  status     WorkflowRunStatus @default(PENDING)
  output     String            @default("") @db.Text
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime          @default(now())

  run      WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([runId, position])
}

// -----------------------------
// Agent profiles (AGENTS.md personas)
// -----------------------------

model AgentProfile {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  body        String    @db.Text
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy   User                 @relation("AgentProfileCreator", fields: [createdById], references: [id], onDelete: Restrict)
  ticketLinks TicketAgentProfile[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

// -----------------------------
// Pull request history (one ticket → many PRs)
// -----------------------------

enum TicketPullRequestStatus {
  OPEN
  MERGED
  CLOSED
  SUPERSEDED
}

model TicketPullRequest {
  id           String                  @id @default(cuid())
  ticketId     String
  url          String
  status       TicketPullRequestStatus @default(OPEN)
  branch       String?
  targetBranch String?
  summary      String?                 @db.Text
  filesChanged Int?
  additions    Int?
  deletions    Int?
  openedAt     DateTime                @default(now())
  mergedAt     DateTime?
  closedAt     DateTime?
  supersededAt DateTime?

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@unique([ticketId, url])
  @@index([ticketId, openedAt])
}

model TicketAgentProfile {
  ticketId       String
  agentProfileId String
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  ticket       Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  agentProfile AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)

  @@id([ticketId, agentProfileId])
  @@index([agentProfileId])
}

// -----------------------------
// Conversations & Messages (per-ticket chat: human + agent authors)
// -----------------------------

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

enum MessageStatus {
  PENDING
  STREAMING
  COMPLETE
  ERROR
}

enum MessageMentionTargetType {
  USER
  AGENT
  TICKET
}

model Conversation {
  id          String   @id @default(cuid())
  workspaceId String
  ticketId    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ticket    Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([workspaceId, createdAt])
}

// Polymorphic author: exactly one of authorUserId / authorAgentId must be set
// for role=USER|AGENT; both null is permitted for role=SYSTEM. The invariant
// is enforced via a raw-SQL CHECK constraint added in the migration.
model Message {
  id              String        @id @default(cuid())
  conversationId  String
  workspaceId     String
  authorUserId    String?
  authorAgentId   String?
  role            MessageRole
  body            String        @default("") @db.Text
  status          MessageStatus @default(COMPLETE)
  agentJobId      String?
  // Per-message attribution to a workflow step. Set by the mirror service
  // from the wire event's stepRunId (which Electron main stamps from the
  // session's currentStepRunId at the moment of write). A single AgentJob
  // can span multiple steps (warm-send within one Claude session), so the
  // FK has to live on Message — not AgentJob — to attribute correctly.
  workflowStepRunId String?
  idempotencyKey  String        @unique
  parentId        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conversation Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authorUser   User?             @relation("MessageAuthorUser",  fields: [authorUserId],  references: [id], onDelete: SetNull)
  authorAgent  Agent?            @relation("MessageAuthorAgent", fields: [authorAgentId], references: [id], onDelete: SetNull)
  agentJob     AgentJob?         @relation(fields: [agentJobId], references: [id], onDelete: SetNull)
  workflowStepRun WorkflowStepRun? @relation(fields: [workflowStepRunId], references: [id], onDelete: SetNull)
  parent       Message?          @relation("MessageParent", fields: [parentId], references: [id], onDelete: SetNull)
  replies      Message[]         @relation("MessageParent")
  chunks       MessageChunk[]
  mentions     MessageMention[]
  reactions    MessageReaction[]

  @@index([conversationId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([authorUserId])
  @@index([authorAgentId])
  @@index([agentJobId])
  @@index([workflowStepRunId])
}

// Append-only stream chunks. Agent runner writes deltas here during STREAMING;
// on COMPLETE the runner concatenates and writes the final body to Message.body
// in a single update. Avoids MVCC/TOAST churn from in-place patching.
model MessageChunk {
  id        String   @id @default(cuid())
  messageId String
  sequence  Int
  delta     String   @db.Text
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, sequence])
  @@index([messageId, sequence])
}

// Denormalized mentions parsed from the message body. targetId is polymorphic
// per targetType (USER|AGENT|TICKET) — no FK by design; resolution is done in
// the service layer with explicit workspace-scope checks.
model MessageMention {
  id         String                   @id @default(cuid())
  messageId  String
  targetType MessageMentionTargetType
  targetId   String
  createdAt  DateTime                 @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([targetType, targetId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String?
  agentId   String?
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User?   @relation("MessageReactionUser",  fields: [userId],  references: [id], onDelete: Cascade)
  agent   Agent?  @relation("MessageReactionAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@unique([messageId, agentId, emoji])
  @@index([messageId])
}
