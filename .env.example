DATABASE_URL=postgresql://planbooq:planbooq@localhost:5656/planbooq
NEXTAUTH_URL=http://localhost:3636
NEXTAUTH_SECRET=replace-with-`openssl rand -base64 32`
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM=Planbooq <noreply@planbooq.local>
# GitHub OAuth — create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: $NEXTAUTH_URL/api/auth/callback/github
# Leave both blank to disable the GitHub sign-in button.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
ABLY_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set INNGEST_DEV=1 in local dev so the Inngest SDK doesn't expect a signing key
# DEV ONLY — must be unset in production
INNGEST_DEV=1
# INNGEST_REQUIRED=true # Set in real production deploys to enforce Inngest signing.
# Set to "true" only when running behind a trusted proxy that strips/sets Host correctly. Required for non-localhost deployments.
AUTH_TRUST_HOST=true
