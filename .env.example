DATABASE_URL=postgresql://planbooq:planbooq@localhost:5656/planbooq
NEXTAUTH_URL=http://localhost:3636
NEXTAUTH_SECRET=replace-with-`openssl rand -base64 32`
# GitHub OAuth — required. Create an OAuth app at https://github.com/settings/developers
# Authorization callback URL: $NEXTAUTH_URL/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
# GitHub webhook — used to auto-move a ticket to "Completed" when its linked
# PR is merged. Generate with `openssl rand -hex 32` and paste the same value
# into the repo's webhook settings on GitHub. See docs/github-webhook.md.
GITHUB_WEBHOOK_SECRET=
ABLY_API_KEY=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Set INNGEST_DEV=1 in local dev so the Inngest SDK doesn't expect a signing key
# DEV ONLY — must be unset in production
INNGEST_DEV=1
# INNGEST_REQUIRED=true # Set in real production deploys to enforce Inngest signing.
# Production setup: see docs/inngest-prod.md (Vercel env vars + Inngest Cloud sync).
# Set to "true" only when running behind a trusted proxy that strips/sets Host correctly. Required for non-localhost deployments.
AUTH_TRUST_HOST=true
# AWS S3 — required. Stores attachments (screenshots, videos, and other
# artifacts) uploaded via /api/attachments. The bucket should be private;
# objects are served back through the app's auth-checked stream routes.
# AWS_S3_ENDPOINT may point at a non-AWS S3-compatible service (e.g. R2, MinIO).
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
